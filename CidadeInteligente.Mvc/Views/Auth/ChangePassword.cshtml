@using CidadeInteligente.Domain.Constants
@model CidadeInteligente.Application.Commands.GetOrRemoveUserTokenRecoverPassword.GetOrRemoveUserTokenRecoverPasswordCommandResult;

@{
    ViewData["Title"] = "Alterar Senha";
    ViewData["ShowFooter"] = false;
}

@section Styles
{
    <link rel="stylesheet" href="~/css/auth.css">
}

<div class="limiter">
    <div class="container-login100">
        <div class="main">
            <div class="container">
                <div class="row justify-content-center align-items-center">
                    <div class="col-12 col-md-5 painel">
                        <div class="img-logo-cidade">
                            <img src="img/icon-auth.png">
                        </div>
                        <h3 class="text-center title mb-3">Alteração de Senha</h3>
                        <form class="form">
                            <input max="@UserConstraints.TokenRecoverPasswordMaxLength" required type="hidden" name="token" value="@Model.Token">
                            <label class="text-dark">Olá <b>@Model.UserName</b>, digite sua nova senha:</label>
                            <div class="inputIcon">
                                <input required type="password" minlength="@UserConstraints.RawPasswordMinLength" name="newPassword" class="form-input" placeholder="Digite a sua nova senha">
                                <i class="mdi mdi-key"></i>
                            </div>
                            <div class="inputIcon">
                                <input required type="password" minlength="@UserConstraints.RawPasswordMinLength" name="confirmNewPassword" class="form-input" placeholder="Confirme a sua nova senha">
                                <i class="mdi mdi-key"></i>
                            </div>
                        </form>
                        <button type="button" class="btn mb-2 btn-strong-red btn-block btn-changePassword">Alterar Senha</button>
                        <div class="text-center font-weight-bold mt-3">&copy; @DateTime.UtcNow.Year</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/js/change-password.js"></script>
}
