@using CidadeInteligente.Application.Queries.GetProjects
@using static CidadeInteligente.Application.Queries.GetProjects.GetProjectsQueryResult
@model GetProjectsQueryResult;

@{
    ViewData["Title"] = "Projetos";
    ViewData["ShowHeader"] = false;
}

@section Styles
{
    <link rel="stylesheet" href="~/css/projects.css">
}

<div class="container-navbar">
    <partial name="_Header" />
    <h3 class="title">Projeto Cidade Inteligente</h3>
</div>
<div class="subtitle">
    <p class="text-center">
        O projeto Cidade Inteligente consiste na representação em minuatura funcional, de um circuito de ambientes dividos em várias áreas.
    </p>
</div>

<main id="noSpaceHeader">
    <div class="galery">
        <div class="row justify-content-center mt-3">
            @if (!Model.Data.Any())
            {
                <h3 class="text-center">Nenhum projeto cadastrado</h3>
            }
            else foreach (ProjectViewModel project in Model.Data)
            {
                bool hasMoreThanOneMedia = project.Medias.Count() > 1;
                <div class="col-12 col-sm-12 col-lg-3 col-md-3 mb-2">
                    <div class="card">
                        <div id="mediaIndicators-@project.ProjectId" class="carousel slide" data-ride="carousel">
                            @if (hasMoreThanOneMedia)
                            {
                                <ol class="carousel-indicators">
                                    <li data-target="#mediaIndicators-@project.ProjectId" data-slide-to="@project.Medias.First().MediaId" class="active"></li>
                                    @for (int i = 1; i < project.Medias.Count(); i++)
                                    {
                                        <li data-target="#mediaIndicators-@project.ProjectId" data-slide-to="@project.Medias.ElementAt(i).MediaId"></li>
                                    }
                                </ol>
                            }
                            <div class="carousel-inner">
                                @if (project.Medias.First().IsVideo)
                                {
                                    <div class="carousel-item active">
                                        <video loop muted autoplay class="d-block" style="width:inherit" preload="metadata" src="@project.Medias.First().Path"></video>
                                    </div>
                                }
                                else
                                {
                                    <div class="carousel-item active">
                                        <img class="d-block w-100 img-card" src="@project.Medias.First().Path">
                                    </div>
                                }
                                @if (hasMoreThanOneMedia)
                                {
                                    for (int i = 1; i < project.Medias.Count(); i++)
                                    {
                                        if (project.Medias.ElementAt(i).IsVideo)
                                        {
                                            <div class="carousel-item">
                                                <video class="d-block" style="width:inherit" preload="metadata" src="@project.Medias.ElementAt(i).Path"></video>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="carousel-item">
                                                <img class="d-block w-100 img-card" src="@project.Medias.ElementAt(i).Path">
                                            </div>
                                        }
                                    }
                                }
                            </div>
                            @if (hasMoreThanOneMedia)
                            {
                                <a class="carousel-control-prev" href="#mediaIndicators-@project.ProjectId" role="button" data-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    <span class="sr-only">Previous</span>
                                </a>
                                <a class="carousel-control-next" href="#mediaIndicators-@project.ProjectId" role="button" data-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    <span class="sr-only">Next</span>
                                </a>
                            }
                        </div>
                        <div class="card-body">
                            <h4 class="card-title">@project.Title</h4>
                            <p class="card-text">@project.Description</p>
                            <a href="/projects/@project.ProjectId/view" target="_blank" class="btn btn-default-red btn-block">
                                Ver Mais Sobre
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="row justify-content-center mt-3">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                if (i != Model.Page)
                {
                    <a href="/?page=@i">
                        <button class="btn btn-default-red m-1">@i</button>
                    </a>
                }
                else
                {
                    <button class="btn btn-strong-red m-1" disabled>@i</button>
                }
            }
        </div>
    </div>
</main>

@section Scripts
{
    <script src="~/js/projects.js"></script>
}
