{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss.fff} {Level:u3}] (CorrelationId={CorrelationId}) {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "Database": "Server=(localdb)\\mssqllocaldb;Database=CidadeInteligente;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "FileStorage": {
    "ContainerName": "project-medias"
  },
  "SendGrid": {
    "SenderEmail": "noreply@cidadeinteligente.com"
  },
  "Pagination": {
    "MaxPageSize": 8
  }
}
